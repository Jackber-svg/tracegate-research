{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Jackber-svg/tracegate-research/schemas/PHYSICAL_KPI_GATES.schema.json",
  "title": "TraceGate Research PHYSICAL_KPI_GATES.json",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "version",
    "gates"
  ],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "gate_id",
          "input_file",
          "thresholds"
        ],
        "properties": {
          "gate_id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "input_file": {
            "type": "string",
            "minLength": 1
          },
          "allowed_modes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "requires_full_window": {
            "type": "boolean"
          },
          "thresholds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": [
                "metric",
                "op",
                "value"
              ],
              "properties": {
                "metric": {
                  "type": "string",
                  "minLength": 1
                },
                "source": {
                  "type": "string"
                },
                "op": {
                  "type": "string",
                  "enum": [
                    "lt",
                    "lte",
                    "gt",
                    "gte",
                    "eq",
                    "<",
                    "<=",
                    ">",
                    ">=",
                    "=="
                  ]
                },
                "value": {
                  "type": "number"
                },
                "fail_status": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
